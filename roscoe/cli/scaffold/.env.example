# =============================================================================
# Environment variables for __PROJECT_NAME__
# =============================================================================
#
# 1. Copy this file:  cp .env.example .env
# 2. Fill in the keys for the provider you chose in agent_config.yaml.
# 3. Never commit .env — it holds secrets.
#
# Only the provider you're using needs a key. Everything else can stay blank.
# =============================================================================

# --- LLM provider keys (fill in the one matching your agent_config.yaml) -----
OPENAI_API_KEY=
# AZURE_OPENAI_KEY=
# AZURE_OPENAI_ENDPOINT=https://my-resource.openai.azure.com
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# --- OpenRouter / other OpenAI-compatible endpoints -------------------------
# Set provider: openai + base_url in agent_config.yaml, then:
# OPENROUTER_API_KEY=

# --- Connector credentials (only if you use connectors) ---------------------
# GITHUB_TOKEN=ghp_...
# JIRA_EMAIL=
# JIRA_API_TOKEN=
# JIRA_BASE_URL=https://yourorg.atlassian.net
# SERVICENOW_INSTANCE_URL=https://dev12345.service-now.com
# SERVICENOW_USERNAME=
# SERVICENOW_PASSWORD=
# NOTION_TOKEN=
# MS_CLIENT_ID=
# MS_CLIENT_SECRET=
# MS_TENANT_ID=
# MS_MAILBOX=user@org.com
# SP_SITE_ID=
# GOOGLE_SA_KEY_FILE=path/to/service-account.json
# GOOGLE_SUBJECT=user@yourdomain.com
# SNOWFLAKE_ACCOUNT=
# SNOWFLAKE_USER=
# SNOWFLAKE_PASSWORD=
# SNOWFLAKE_WAREHOUSE=
# SNOWFLAKE_DATABASE=
